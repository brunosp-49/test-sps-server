    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/supertest": "^7.2.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
